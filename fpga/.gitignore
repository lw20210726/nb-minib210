# ==========================================================================
# Vivado 工程忽略规则
# 只保留可再生的源头：*.xpr（工程文件）与 *.srcs/（源码 + IP/.xci 定义）。
# 其余目录均由 Vivado 从上述源头重新生成，不入库。
# ==========================================================================

# --- Vivado 生成目录（综合/实现/IP 输出产物、缓存、仿真、硬件管理器等）---
*.cache/
*.gen/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
.Xil/

# --- 日志 / 日志备份 / 启动脚本记录 ---
vivado*.jou
vivado*.log
vivado*.backup.jou
vivado*.backup.log
*.str

# --- archive_project 生成的摘要 ---
archive_project_summary.txt
